---
import { profile } from '@data/profile';
---

<footer data-testid="footer" class="mb-10 mt-12 text-center text-sm text-ink-soft">
	<div class="flex flex-col items-center gap-3">
		<p>最終更新日: {profile.lastUpdated}</p>
		<div class="flex flex-wrap items-center justify-center gap-4">
			{profile.links.map((link) => (
				<a
					href={link.href}
					class="rounded-full border border-ink/10 bg-white/90 px-3 py-1 text-xs text-ink transition hover:border-orange hover:text-orange"
					target="_blank"
					rel="noopener"
				>
					{link.label}
				</a>
			))}
		</div>
		<p class="text-xs">© {new Date().getFullYear()} K1npiragobou</p>
	</div>
</footer>
