---
import { Astronav, MenuIcon, MenuItems } from 'astro-navbar';
import { profile } from '@data/profile';

const baseUrl = import.meta.env.BASE_URL;

const menuitems = [
	{
		title: 'Home',
		path: `${baseUrl}`,
	},
	{
		title: 'プロフィール',
		path: `${baseUrl}#profile`,
	},
	{
		title: 'リンク',
		path: `${baseUrl}#links`,
	},
	{
		title: 'ステータス',
		path: `${baseUrl}#status`,
	},
	{
		title: 'Works',
		path: `${baseUrl}works/`,
	},
];
---

<header data-testId="header" class="my-6 flex flex-col items-center justify-between gap-4 lg:flex-row">
	<Astronav>
		<div class="flex w-full items-center justify-between lg:w-auto">
			<a
				href={baseUrl}
				class="rounded-full bg-white/90 px-4 py-2 text-sm font-medium text-ink shadow-sm ring-1 ring-ink/10"
			>
				{profile.vrcName}
			</a>
			<div class="block lg:hidden">
				<MenuIcon class="h-4 w-4 text-ink" />
			</div>
		</div>
		<MenuItems class="mt-2 hidden w-full lg:mt-0 lg:flex lg:w-auto">
			<ul class="flex flex-col gap-2 lg:flex-row lg:items-center lg:gap-4">
				{
					menuitems.map((item) => (
						<li>
							<a
								aria-label="navigation link"
								href={item.path}
								class="flex rounded-full px-3 py-2 text-sm text-ink-soft transition hover:bg-orange-soft hover:text-ink"
							>
								{item.title}
							</a>
						</li>
					))
				}
			</ul>
		</MenuItems>
	</Astronav>
</header>
